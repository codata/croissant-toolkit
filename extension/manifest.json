{
    "manifest_version": 3,
    "name": "Croissant Converter",
    "version": "1.0.0",
    "description": "Convert any web page into Croissant JSON-LD metadata format",
    "permissions": ["sidePanel", "activeTab", "scripting"],
    "side_panel": {
        "default_path": "sidepanel.html"
    },
    "sidebar_action": {
        "default_panel": "sidepanel.html",
        "default_title": "Croissant Converter",
        "default_icon": {
            "16": "icons/croissant-16.png",
            "48": "icons/croissant-48.png",
            "128": "icons/croissant-128.png"
        }
    },
    "background": {
        "service_worker": "background.js",
        "scripts": ["background.js"]
    },
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["content.js"]
        }
    ],
    "action": {
        "default_title": "Croissant Converter",
        "default_icon": {
            "16": "icons/croissant-16.png",
            "48": "icons/croissant-48.png",
            "128": "icons/croissant-128.png"
        }
    },
    "icons": {
        "16": "icons/croissant-16.png",
        "48": "icons/croissant-48.png",
        "128": "icons/croissant-128.png"
    },
    "browser_specific_settings": {
        "gecko": {
            "id": "croissant-converter@example.com",
            "strict_min_version": "109.0"
        }
    }
}
